      "html": "\n<div class=\"font-nunito bg-[#FFFDD0] text-[#2B1E16] dark:bg-[#2B1E16] dark:text-[#FFFDD0] transition-colors duration-500 overflow-x-hidden min-h-[4000px]\" data-kid=\"0\">\n  <style data-kid=\"1\">\n    @import url('https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=Nunito:wght@400;600;700;800;900&family=Quicksand:wght@400;500;600;700&display=swap');\n    @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n    .clay-grain {\n      position: relative;\n    }\n    .clay-grain::before {\n      content: \"\";\n      position: absolute;\n      inset: 0;\n      width: 100%;\n      height: 100%;\n      background-image: url(\"https://www.transparenttextures.com/patterns/natural-paper.png\");\n      opacity: 0.15;\n      pointer-events: none;\n      z-index: 100;\n      mix-blend-mode: multiply;\n    }\n\n    :root {\n      --clay-sage: #9DC183;\n      --clay-peach: #FFDAB9;\n      --clay-cream: #FFFDD0;\n      --clay-brown: #2B1E16;\n      --clay-terracotta: #E2725B;\n    }\n\n    .font-recoleta { font-family: 'DM Serif Display', serif; }\n    .font-nunito { font-family: 'Nunito', sans-serif; }\n\n    /* Light Mode Claymorphism */\n    .clay-out {\n      box-shadow: 20px 20px 45px rgba(0, 0, 0, 0.07), \n                  -15px -15px 35px rgba(255, 255, 255, 0.95),\n                  inset 2px 2px 4px rgba(255, 255, 255, 0.4);\n      border: 1px solid rgba(255, 255, 255, 0.4);\n    }\n    .clay-inner {\n      box-shadow: inset 10px 10px 20px rgba(0, 0, 0, 0.04), \n                  inset -10px -10px 20px rgba(255, 255, 255, 0.9);\n    }\n    .clay-btn {\n      box-shadow: 10px 10px 20px rgba(0, 0, 0, 0.1), \n                  -5px -5px 15px rgba(255, 255, 255, 0.4),\n                  inset 4px 4px 8px rgba(255, 255, 255, 0.4),\n                  inset -4px -4px 8px rgba(0, 0, 0, 0.08);\n    }\n    .clay-btn:active {\n      box-shadow: inset 6px 6px 12px rgba(0, 0, 0, 0.15), \n                  inset -6px -6px 12px rgba(255, 255, 255, 0.1);\n      transform: scale(0.96);\n    }\n\n    /* Dark Mode Claymorphism */\n    .dark .clay-out {\n      box-shadow: 25px 25px 50px rgba(0, 0, 0, 0.5), \n                  -10px -10px 30px rgba(255, 255, 255, 0.05),\n                  inset 1px 1px 2px rgba(255, 255, 255, 0.05);\n      border: 1px solid rgba(255, 255, 255, 0.04);\n    }\n    .dark .clay-inner {\n      box-shadow: inset 12px 12px 24px rgba(0, 0, 0, 0.4), \n                  inset -12px -12px 24px rgba(255, 255, 255, 0.02);\n    }\n    .dark .clay-btn {\n      box-shadow: 12px 12px 24px rgba(0, 0, 0, 0.4), \n                  -4px -4px 12px rgba(255, 255, 255, 0.05),\n                  inset 2px 2px 4px rgba(255, 255, 255, 0.1),\n                  inset -2px -2px 4px rgba(0, 0, 0, 0.3);\n    }\n\n    /* Animations */\n    @keyframes float {\n      0%, 100% { transform: translateY(0) rotate(0); }\n      50% { transform: translateY(-30px) rotate(5deg); }\n    }\n    .animate-float { animation: float 6s ease-in-out infinite; }\n\n    @keyframes orbit-slow {\n      from { transform: rotate(0deg) translateX(250px) rotate(0deg); }\n      to { transform: rotate(360deg) translateX(250px) rotate(-360deg); }\n    }\n    .animate-orbit { animation: orbit-slow 30s linear infinite; }\n\n    .blob-glow {\n      filter: blur(80px);\n      opacity: 0.3;\n    }\n\n    .puffy-pill {\n      border-radius: 9999px;\n      background: var(--clay-peach);\n      box-shadow: inset 12px 12px 24px rgba(255, 255, 255, 0.6),\n                  inset -12px -12px 24px rgba(0, 0, 0, 0.15),\n                  15px 15px 30px rgba(0,0,0,0.05);\n    }\n    .dark .puffy-pill {\n      background: #4A3728;\n      box-shadow: inset 10px 10px 20px rgba(255, 255, 255, 0.05),\n                  inset -10px -10px 20px rgba(0, 0, 0, 0.3);\n    }\n  </style>\n\n  \n  <nav class=\"absolute top-6 left-1/2 -translate-x-1/2 z-50 w-[90%] max-w-5xl\" data-kid=\"2\">\n    <div class=\"clay-out bg-white/80 dark:bg-[#2B1E16]/80 backdrop-blur-xl rounded-full px-8 py-4 flex items-center justify-between\" data-kid=\"3\">\n      <div class=\"flex items-center gap-2\" data-kid=\"4\">\n        <div class=\"w-10 h-10 rounded-xl bg-[var(--clay-sage)] clay-btn flex items-center justify-center\" data-kid=\"5\">\n          <i class=\"ti ti-brain text-white text-xl\" data-kid=\"6\"></i>\n        </div>\n        <span class=\"font-recoleta text-2xl font-bold tracking-tight\" data-kid=\"7\">Kintsugi AI</span>\n      </div>\n      <div class=\"hidden md:flex items-center gap-8 font-semibold\" data-kid=\"8\">\n        <a href=\"#\" class=\"hover:text-[var(--clay-sage)] transition-colors\" data-kid=\"9\">Platform</a>\n        <a href=\"#\" class=\"hover:text-[var(--clay-sage)] transition-colors\" data-kid=\"10\">Methods</a>\n        <a href=\"#\" class=\"hover:text-[var(--clay-sage)] transition-colors\" data-kid=\"11\">Pricing</a>\n      </div>\n      <div class=\"flex items-center gap-4\" data-kid=\"12\">\n        <button class=\"md:block hidden font-bold hover:opacity-70\" data-kid=\"13\">Log in</button>\n        <button class=\"clay-btn bg-[var(--clay-sage)] text-white px-6 py-2 rounded-full font-bold transition-transform hover:scale-105\" data-kid=\"14\">\n          Get Started\n        </button>\n      </div>\n    </div>\n  </nav>\n\n  \n  <section class=\"relative min-h-[850px] flex flex-col items-center justify-center pt-32 pb-20 px-4 clay-grain\" data-kid=\"15\">\n    \n    <div class=\"absolute inset-0 z-0 pointer-events-none\" data-kid=\"16\">\n      <div class=\"absolute top-[20%] left-[10%] w-96 h-96 bg-[var(--clay-sage)] rounded-full blob-glow animate-pulse\" data-kid=\"17\"></div>\n      <div class=\"absolute bottom-[20%] right-[10%] w-80 h-80 bg-[var(--clay-peach)] rounded-full blob-glow animate-pulse\" style=\"animation-delay: 2s;\" data-kid=\"18\"></div>\n      \n      <div class=\"hidden dark:block absolute top-[10%] right-[15%] w-64 h-64 bg-[#FFDAB9]/10 rounded-full blob-glow animate-pulse\" data-kid=\"19\"></div>\n      \n      \n      <div class=\"absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full h-full max-w-4xl max-h-[600px]\" data-kid=\"20\">\n        <div class=\"absolute top-0 left-0 w-32 h-32 puffy-pill animate-orbit\" style=\"animation-duration: 40s;\" data-kid=\"21\">\n          <div class=\"absolute inset-0 flex items-center justify-center\" data-kid=\"22\">\n            <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/sparkles.svg\" class=\"w-12 h-12\" alt=\"sparkle\" data-kid=\"23\">\n          </div>\n        </div>\n        <div class=\"absolute bottom-0 right-0 w-24 h-24 puffy-pill animate-orbit bg-[var(--clay-sage)] opacity-80\" style=\"animation-duration: 35s; animation-direction: reverse;\" data-kid=\"24\">\n          <div class=\"absolute inset-0 flex items-center justify-center\" data-kid=\"25\">\n            <i class=\"ti ti-message-circle text-white text-3xl\" data-kid=\"26\"></i>\n          </div>\n        </div>\n        <div class=\"absolute top-1/2 left-0 w-20 h-20 puffy-pill animate-orbit\" style=\"animation-duration: 25s; animation-delay: -5s;\" data-kid=\"27\"></div>\n        <div class=\"absolute top-0 right-1/4 w-16 h-16 puffy-pill bg-[#E2725B] animate-orbit\" style=\"animation-duration: 50s;\" data-kid=\"28\"></div>\n        \n        <div class=\"absolute bottom-1/4 left-1/4 w-32 h-12 puffy-pill bg-[#9DC183]/40 animate-orbit\" style=\"animation-duration: 45s; animation-delay: -10s;\" data-kid=\"29\"></div>\n      </div>\n    </div>\n\n    <div class=\"relative z-10 text-center max-w-5xl mx-auto\" data-kid=\"30\">\n      <div class=\"inline-flex items-center gap-2 bg-white/40 dark:bg-black/20 rounded-full px-4 py-2 mb-8 clay-inner border border-white/20\" data-kid=\"31\">\n        <span class=\"flex h-2 w-2 rounded-full bg-[var(--clay-sage)]\" data-kid=\"32\"></span>\n        <span class=\"text-sm font-bold uppercase tracking-wider opacity-70\" data-kid=\"33\">The Buttery Smooth AI Interviewer</span>\n      </div>\n      <h1 class=\"font-recoleta text-7xl md:text-9xl text-[var(--clay-brown)] dark:text-[#FFFDD0] mb-8 leading-[0.95] tracking-tighter\" data-kid=\"34\">\n        Interviewing, <br data-kid=\"35\">\n        <span class=\"text-[#7ea362] dark:text-[#9DC183] italic drop-shadow-[0_2px_1px_rgba(255,255,255,1)] dark:drop-shadow-none\" data-kid=\"36\">Made Human.</span>\n      </h1>\n      <p class=\"font-nunito text-xl md:text-2xl text-[var(--clay-brown)]/60 dark:text-[#FFFDD0]/60 mb-12 max-w-2xl mx-auto leading-relaxed\" data-kid=\"37\">\n        Transform anxiety into confidence with AI that's as soft as clay and as sharp as a diamond. Master every conversation.\n      </p>\n      \n      <div class=\"flex flex-col sm:flex-row items-center justify-center gap-6\" data-kid=\"38\">\n        <button class=\"clay-btn bg-[var(--clay-terracotta)] text-white px-10 py-5 rounded-[30px] text-xl font-black transition-all hover:-translate-y-1\" data-kid=\"39\">\n          Start Practicing Free\n        </button>\n        <button class=\"clay-out bg-white dark:bg-[#2B1E16] px-10 py-5 rounded-[30px] text-xl font-bold flex items-center gap-3 transition-all hover:-translate-y-1\" data-kid=\"40\">\n          <i class=\"ti ti-player-play-filled text-[var(--clay-sage)]\" data-kid=\"41\"></i>\n          Watch Demo\n        </button>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-20 px-4 bg-[#FFFDD0]/50 dark:bg-[#2B1E16]/50\" data-kid=\"42\">\n    <div class=\"max-w-6xl mx-auto\" data-kid=\"43\">\n      <div class=\"grid grid-cols-1 md:grid-cols-3 gap-10\" data-kid=\"44\">\n        <div class=\"clay-inner bg-[#FFFDD0] dark:bg-[#2B1E16] rounded-[60px] py-14 px-8 text-center group transition-all hover:-translate-y-2\" data-kid=\"45\">\n          <div class=\"font-recoleta text-7xl text-[var(--clay-sage)] mb-4 transition-transform group-hover:scale-105 drop-shadow-[2px_2px_2px_rgba(255,255,255,0.8)] dark:drop-shadow-[1px_1px_1px_rgba(0,0,0,0.5)]\" data-kid=\"46\">98%</div>\n          <div class=\"font-nunito text-xs font-black uppercase tracking-[0.2em] opacity-50\" data-kid=\"47\">Confidence Boost</div>\n        </div>\n        <div class=\"clay-inner bg-[#FFFDD0] dark:bg-[#2B1E16] rounded-[60px] py-14 px-8 text-center group transition-all hover:-translate-y-2\" data-kid=\"48\">\n          <div class=\"font-recoleta text-7xl text-[var(--clay-terracotta)] mb-4 transition-transform group-hover:scale-105 drop-shadow-[2px_2px_2px_rgba(255,255,255,0.8)] dark:drop-shadow-[1px_1px_1px_rgba(0,0,0,0.5)]\" data-kid=\"49\">50k+</div>\n          <div class=\"font-nunito text-xs font-black uppercase tracking-[0.2em] opacity-50\" data-kid=\"50\">Sessions Done</div>\n        </div>\n        <div class=\"clay-inner bg-[#FFFDD0] dark:bg-[#2B1E16] rounded-[60px] py-14 px-8 text-center group transition-all hover:-translate-y-2\" data-kid=\"51\">\n          <div class=\"font-recoleta text-7xl text-[var(--clay-sage)] mb-4 transition-transform group-hover:scale-105 drop-shadow-[2px_2px_2px_rgba(255,255,255,0.8)] dark:drop-shadow-[1px_1px_1px_rgba(0,0,0,0.5)]\" data-kid=\"52\">4.9/5</div>\n          <div class=\"font-nunito text-xs font-black uppercase tracking-[0.2em] opacity-50\" data-kid=\"53\">User Satisfaction</div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-32 px-4 relative clay-grain\" data-kid=\"54\">\n    <div class=\"max-w-6xl mx-auto\" data-kid=\"55\">\n      <div class=\"text-center mb-24\" data-kid=\"56\">\n        <h2 class=\"font-recoleta text-5xl md:text-6xl text-[var(--clay-brown)] dark:text-[#FFFDD0] mb-6\" data-kid=\"57\">Buttery smooth features.</h2>\n        <p class=\"font-nunito text-xl text-[var(--clay-brown)]/50 dark:text-[#FFFDD0]/50 max-w-xl mx-auto\" data-kid=\"58\">\n          We've distilled years of coaching into an interface that feels like play.\n        </p>\n      </div>\n\n      <div class=\"grid grid-cols-1 md:grid-cols-12 gap-8 items-stretch\" data-kid=\"59\">\n        \n        <div class=\"md:col-span-7 clay-out bg-[var(--clay-sage)] rounded-[50px] p-12 text-white relative overflow-hidden flex flex-col justify-end h-full group cursor-default\" data-kid=\"60\">\n          <div class=\"absolute top-10 right-10 w-48 h-48 bg-white/20 rounded-full blur-3xl group-hover:scale-150 transition-transform duration-1000\" data-kid=\"61\"></div>\n          <div class=\"relative z-10\" data-kid=\"62\">\n            <div class=\"w-16 h-16 rounded-2xl bg-white/30 clay-btn flex items-center justify-center mb-8\" data-kid=\"63\">\n              <i class=\"ti ti-brain text-4xl\" data-kid=\"64\"></i>\n            </div>\n            <h3 class=\"font-recoleta text-5xl mb-6\" data-kid=\"65\">Deep Emotional IQ</h3>\n            <p class=\"text-xl text-white/90 max-w-md leading-relaxed\" data-kid=\"66\">Our AI doesn't just hear your words; it understands the sentiment, pacing, and warmth behind your delivery.</p>\n          </div>\n        </div>\n\n        \n        <div class=\"md:col-span-5 clay-out bg-[var(--clay-peach)] rounded-[50px] p-12 text-[var(--clay-brown)] flex flex-col justify-between h-full min-h-[480px]\" data-kid=\"67\">\n          <div class=\"w-16 h-16 rounded-2xl bg-white/40 clay-btn flex items-center justify-center\" data-kid=\"68\">\n            <i class=\"ti ti-message-circle text-4xl\" data-kid=\"69\"></i>\n          </div>\n          <div class=\"mt-auto\" data-kid=\"70\">\n            <h3 class=\"font-recoleta text-4xl mb-4\" data-kid=\"71\">Live Empathy Scoring</h3>\n            <p class=\"text-xl opacity-70\" data-kid=\"72\">Get real-time visual cues that help you adjust your tone to be more approachable and professional.</p>\n          </div>\n        </div>\n\n        \n        <div class=\"md:col-span-5 clay-out bg-white dark:bg-[#1A110B] rounded-[50px] p-6 h-full min-h-[400px]\" data-kid=\"73\">\n          <div class=\"w-full h-full rounded-[40px] overflow-hidden relative group aspect-[4/5] md:aspect-auto\" data-kid=\"74\">\n            <video src=\"https://videos.pexels.com/video-files/5442624/5442624-sd_540_960_25fps.mp4\" poster=\"https://images.pexels.com/videos/5442624/pexels-photo-5442624.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=1200&w=630\" autoplay muted loop playsinline preload=\"metadata\" class=\"w-full h-full object-cover grayscale-[0.2] group-hover:grayscale-0 transition-all duration-500\" data-kid=\"75\"></video>\n            <div class=\"absolute inset-0 bg-gradient-to-t from-black/60 to-transparent flex items-end p-8\" data-kid=\"76\">\n              <div class=\"text-white\" data-kid=\"77\">\n                <p class=\"font-bold text-lg\" data-kid=\"78\">AI Feedback Interface</p>\n                <p class=\"text-sm opacity-70\" data-kid=\"79\">Real-time analysis in action</p>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        \n        <div class=\"md:col-span-7 clay-out bg-[var(--clay-terracotta)] rounded-[50px] p-12 text-white flex flex-col justify-center h-full min-h-[400px]\" data-kid=\"80\">\n          <div class=\"flex items-center gap-6 mb-10\" data-kid=\"81\">\n            <div class=\"flex -space-x-5\" data-kid=\"82\">\n              <img src=\"https://i.pravatar.cc/100?u=1\" class=\"w-14 h-14 rounded-full border-4 border-[var(--clay-terracotta)] clay-out object-cover\" alt=\"avatar\" data-kid=\"83\">\n              <img src=\"https://i.pravatar.cc/100?u=2\" class=\"w-14 h-14 rounded-full border-4 border-[var(--clay-terracotta)] clay-out object-cover\" alt=\"avatar\" data-kid=\"84\">\n              <img src=\"https://i.pravatar.cc/100?u=3\" class=\"w-14 h-14 rounded-full border-4 border-[var(--clay-terracotta)] clay-out object-cover\" alt=\"avatar\" data-kid=\"85\">\n            </div>\n            <span class=\"font-bold text-lg md:text-xl drop-shadow-sm\" data-kid=\"86\">Trusted by 10k+ candidates</span>\n          </div>\n          <h3 class=\"font-recoleta text-5xl mb-6\" data-kid=\"87\">Pacing & Flow Coaching</h3>\n          <p class=\"text-xl text-white/80 max-w-xl\" data-kid=\"88\">Soft haptic reminders to slow down, pause for effect, and breathe through the difficult questions.</p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-32 px-4 clay-grain\" data-kid=\"89\">\n    <div class=\"max-w-4xl mx-auto clay-out bg-[var(--clay-sage)] rounded-[60px] p-16 text-center text-white relative overflow-hidden\" data-kid=\"90\">\n      \n      <div class=\"absolute -top-10 -left-10 w-40 h-40 puffy-pill bg-white/10 blur-xl\" data-kid=\"91\"></div>\n      <div class=\"absolute -bottom-10 -right-10 w-60 h-60 puffy-pill bg-black/5 blur-xl\" data-kid=\"92\"></div>\n      \n      <div class=\"relative z-10\" data-kid=\"93\">\n        <h2 class=\"font-recoleta text-5xl md:text-6xl mb-8\" data-kid=\"94\">Ready for your buttery smooth career?</h2>\n        <p class=\"font-nunito text-xl mb-12 opacity-80 max-w-2xl mx-auto\" data-kid=\"95\">\n          Join thousands of professionals who have mastered the art of human-centric interviewing.\n        </p>\n        <div class=\"flex flex-col sm:flex-row items-center justify-center gap-8\" data-kid=\"96\">\n          <button class=\"clay-btn bg-white text-[var(--clay-sage)] px-12 py-5 rounded-full text-xl font-black transition-all hover:scale-105\" data-kid=\"97\">\n            Start Free Trial\n          </button>\n          <button class=\"font-bold text-xl border-b-2 border-white/40 hover:border-white transition-all pb-1 h-fit leading-none mb-1\" data-kid=\"98\">\n            Talk to an advisor\n          </button>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <footer class=\"py-20 px-4 border-t border-black/5 dark:border-white/5\" data-kid=\"99\">\n    <div class=\"max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-4 gap-12\" data-kid=\"100\">\n      <div class=\"col-span-1 md:col-span-2\" data-kid=\"101\">\n        <div class=\"flex items-center gap-2 mb-6\" data-kid=\"102\">\n          <div class=\"w-10 h-10 rounded-xl bg-[var(--clay-sage)] clay-btn flex items-center justify-center\" data-kid=\"103\">\n            <i class=\"ti ti-brain text-white text-xl\" data-kid=\"104\"></i>\n          </div>\n          <span class=\"font-recoleta text-3xl font-bold tracking-tight\" data-kid=\"105\">Kintsugi AI</span>\n        </div>\n        <p class=\"font-nunito text-lg opacity-50 max-w-xs mb-8\" data-kid=\"106\">\n          Crafting more human interactions in an increasingly automated world.\n        </p>\n        <div class=\"flex gap-4\" data-kid=\"107\">\n          <a href=\"#\" class=\"w-14 h-14 rounded-full clay-inner bg-white dark:bg-[#2B1E16] flex items-center justify-center hover:scale-110 transition-transform text-2xl\" data-kid=\"108\">\n            <i class=\"ti ti-brand-twitter\" data-kid=\"109\"></i>\n          </a>\n          <a href=\"#\" class=\"w-14 h-14 rounded-full clay-inner bg-white dark:bg-[#2B1E16] flex items-center justify-center hover:scale-110 transition-transform text-2xl\" data-kid=\"110\">\n            <i class=\"ti ti-brand-linkedin\" data-kid=\"111\"></i>\n          </a>\n          <a href=\"#\" class=\"w-14 h-14 rounded-full clay-inner bg-white dark:bg-[#2B1E16] flex items-center justify-center hover:scale-110 transition-transform text-2xl\" data-kid=\"112\">\n            <i class=\"ti ti-brand-instagram\" data-kid=\"113\"></i>\n          </a>\n        </div>\n      </div>\n      <div data-kid=\"114\">\n        <h4 class=\"font-recoleta text-xl mb-6\" data-kid=\"115\">Product</h4>\n        <ul class=\"space-y-4 font-bold opacity-60\" data-kid=\"116\">\n          <li data-kid=\"117\"><a href=\"#\" class=\"hover:text-[var(--clay-sage)]\" data-kid=\"118\">Features</a></li>\n          <li data-kid=\"119\"><a href=\"#\" class=\"hover:text-[var(--clay-sage)]\" data-kid=\"120\">Case Studies</a></li>\n          <li data-kid=\"121\"><a href=\"#\" class=\"hover:text-[var(--clay-sage)]\" data-kid=\"122\">Reviews</a></li>\n          <li data-kid=\"123\"><a href=\"#\" class=\"hover:text-[var(--clay-sage)]\" data-kid=\"124\">Updates</a></li>\n        </ul>\n      </div>\n      <div data-kid=\"125\">\n        <h4 class=\"font-recoleta text-xl mb-6\" data-kid=\"126\">Company</h4>\n        <ul class=\"space-y-4 font-bold opacity-60\" data-kid=\"127\">\n          <li data-kid=\"128\"><a href=\"#\" class=\"hover:text-[var(--clay-sage)]\" data-kid=\"129\">About Us</a></li>\n          <li data-kid=\"130\"><a href=\"#\" class=\"hover:text-[var(--clay-sage)]\" data-kid=\"131\">Careers</a></li>\n          <li data-kid=\"132\"><a href=\"#\" class=\"hover:text-[var(--clay-sage)]\" data-kid=\"133\">Manifesto</a></li>\n          <li data-kid=\"134\"><a href=\"#\" class=\"hover:text-[var(--clay-sage)]\" data-kid=\"135\">Privacy</a></li>\n        </ul>\n      </div>\n    </div>\n    <div class=\"max-w-6xl mx-auto mt-20 pt-8 border-t border-black/5 dark:border-white/5 flex flex-col md:flex-row justify-between items-center gap-6 opacity-40 font-bold text-sm\" data-kid=\"136\">\n      <p data-kid=\"137\">© 2024 Kintsugi AI Platform. Built with love and clay.</p>\n      <div class=\"flex gap-8\" data-kid=\"138\">\n        <a href=\"#\" data-kid=\"139\">Terms</a>\n        <a href=\"#\" data-kid=\"140\">Cookies</a>\n        <a href=\"#\" data-kid=\"141\">Security</a>\n      </div>\n    </div>\n  </footer>\n</div>\n",
