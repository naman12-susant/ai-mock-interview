      "html": "\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css\" data-kid=\"0\">\n<style data-kid=\"1\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Space+Mono:wght@400;700&display=swap');\n\n  :root {\n    /* These are provided by the theme, but I'll define local helpers for complex effects if needed */\n    --local-grid-line: var(--k-color-border);\n  }\n\n  .font-sans { font-family: var(--k-font-family-body); }\n  .font-heading { font-family: var(--k-font-family-heading); }\n  .font-mono { font-family: 'Space Mono', monospace; }\n\n  .isometric-container {\n    perspective: 2000px;\n    transform-style: preserve-3d;\n  }\n\n  .isometric-base {\n    transform: rotateX(60deg) rotateZ(-45deg);\n    transform-style: preserve-3d;\n    filter: drop-shadow(40px 40px 60px rgba(0, 0, 0, 0.08));\n  }\n\n  .stair-block-face {\n    background: linear-gradient(135deg, #ffffff 0%, #F8F9FA 50%, #E5E7EB 100%);\n    box-shadow: inset 0 1px 1px rgba(255,255,255,1);\n  }\n\n  .glass-panel {\n    background: rgba(255, 255, 255, 0.6);\n    backdrop-filter: blur(12px);\n    border: 1px solid var(--k-color-border);\n  }\n\n  .glass-panel-accent {\n    background: rgba(0, 71, 171, 0.05);\n    backdrop-filter: blur(12px);\n    border: 1px solid rgba(0, 71, 171, 0.1);\n  }\n\n  .grid-bg {\n    background-image: \n      linear-gradient(to right, var(--k-color-border) 1px, transparent 1px),\n      linear-gradient(to bottom, var(--k-color-border) 1px, transparent 1px);\n    background-size: 40px 40px;\n  }\n\n  .stair-block {\n    transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);\n  }\n  \n  .stair-block:hover {\n    transform: translateZ(20px) translateY(-10px);\n  }\n\n  @keyframes float-subtle {\n    0%, 100% { transform: translateY(0); }\n    50% { transform: translateY(-10px); }\n  }\n\n  .animate-float-subtle {\n    animation: float-subtle 4s ease-in-out infinite;\n  }\n\n  .scanline {\n    width: 100%;\n    height: 2px;\n    background: rgba(0, 71, 171, 0.05);\n    position: absolute;\n    top: 0;\n    left: 0;\n    animation: scan 3s linear infinite;\n    pointer-events: none;\n  }\n\n  @keyframes scan {\n    0% { top: 0; }\n    100% { top: 100%; }\n  }\n\n  @keyframes spin-slow {\n    from { transform: rotate(0deg); }\n    to { transform: rotate(360deg); }\n  }\n\n  .animate-spin-slow {\n    animation: spin-slow 15s linear infinite;\n  }\n\n  .perspective-text {\n    transform: perspective(1000px) rotateX(10deg);\n  }\n\n  .nav-link-active::after {\n    content: '';\n    position: absolute;\n    bottom: -4px;\n    left: 0;\n    width: 100%;\n    height: 1px;\n    background: var(--k-color-primary);\n    box-shadow: 0 0 4px var(--k-color-primary);\n  }\n</style>\n\n<div class=\"bg-[var(--k-color-bg-page)] text-[var(--k-color-text-primary)] font-sans selection:bg-[var(--k-color-primary)] selection:text-white\" data-kid=\"2\">\n  \n  \n  <nav class=\"relative z-50 flex items-center justify-between px-12 py-8 border-b border-[var(--k-color-border)] bg-[var(--k-color-bg-page)]/80 backdrop-blur-md\" data-kid=\"3\">\n    <div class=\"flex items-center gap-2\" data-kid=\"4\">\n      <div class=\"w-8 h-8 bg-[var(--k-color-primary)] flex items-center justify-center\" data-kid=\"5\">\n        <i class=\"ti ti-cpu text-white\" data-kid=\"6\"></i>\n      </div>\n      <span class=\"font-mono font-bold tracking-tighter text-xl\" data-kid=\"7\">AUSTERE.TECH</span>\n    </div>\n    <div class=\"hidden md:flex items-center gap-12 font-mono text-[10px] tracking-widest uppercase\" data-kid=\"8\">\n      <a href=\"#\" class=\"relative hover:text-[var(--k-color-primary)] transition-colors nav-link-active\" data-kid=\"9\">ARCHIVE</a>\n      <a href=\"#\" class=\"relative hover:text-[var(--k-color-primary)] transition-colors\" data-kid=\"10\">PROTOCOLS</a>\n      <a href=\"#\" class=\"relative hover:text-[var(--k-color-primary)] transition-colors\" data-kid=\"11\">ANALYTICS</a>\n      <a href=\"#\" class=\"relative hover:text-[var(--k-color-primary)] transition-colors\" data-kid=\"12\">DEPLOY</a>\n    </div>\n    <button class=\"font-mono text-xs border border-[var(--k-color-border)] px-6 py-2 hover:bg-[var(--k-color-primary)] hover:text-white transition-all cursor-pointer\" data-kid=\"13\">\n      INITIALIZE_SESSION\n    </button>\n  </nav>\n\n  \n  <section class=\"relative h-[800px] flex items-center overflow-hidden grid-bg\" data-kid=\"14\">\n    <div class=\"container mx-auto px-12 grid grid-cols-1 lg:grid-cols-2 gap-20 items-center relative z-10\" data-kid=\"15\">\n      \n      \n      <div class=\"max-w-xl\" data-kid=\"16\">\n        <div class=\"inline-flex items-center gap-3 px-3 py-1 border border-[var(--k-color-primary)]/20 bg-[var(--k-color-primary)]/5 text-[var(--k-color-primary)] font-mono text-[10px] tracking-[0.2em] uppercase mb-8\" data-kid=\"17\">\n          <span class=\"w-1.5 h-1.5 bg-[var(--k-color-primary)] animate-pulse\" data-kid=\"18\"></span>\n          System Status: Operational\n        </div>\n        <h1 class=\"text-7xl font-extrabold leading-[1.05] tracking-tighter mb-8 text-[var(--k-color-text-primary)] font-heading\" data-kid=\"19\">\n          Precision <br data-kid=\"20\">Interviewing, <br data-kid=\"21\">\n          <span class=\"text-[var(--k-color-primary)] inline-block relative\" data-kid=\"22\">\n            Engineered.\n            <span class=\"absolute -bottom-2 left-0 w-full h-1 bg-[var(--k-color-accent)]/40\" data-kid=\"23\"></span>\n          </span>\n        </h1>\n        <p class=\"text-[var(--k-color-text-secondary)] text-lg leading-relaxed mb-12 font-light\" data-kid=\"24\">\n          Leverage architectural AI to reconstruct your interview technique. A bespoke platform built on mathematical precision and technical excellence.\n        </p>\n        <div class=\"flex flex-col sm:flex-row gap-4 font-mono\" data-kid=\"25\">\n          <button class=\"bg-[var(--k-color-primary)] text-white px-10 py-5 flex items-center justify-between gap-8 border-b-4 border-[var(--k-color-accent)] hover:border-b-0 hover:translate-y-1 transition-all group cursor-pointer\" data-kid=\"26\">\n            START_RECONSTRUCTION\n            <i class=\"ti ti-arrow-right group-hover:translate-x-2 transition-transform\" data-kid=\"27\"></i>\n          </button>\n          <button class=\"border border-[var(--k-color-border)] px-10 py-5 text-[var(--k-color-text-muted)] hover:bg-[var(--k-color-bg-surface)] hover:text-[var(--k-color-text-primary)] transition-all cursor-pointer\" data-kid=\"28\">\n            VIEW_BLUEPRINTS\n          </button>\n        </div>\n      </div>\n\n      \n      <div class=\"relative h-[600px] isometric-container hidden lg:block\" data-kid=\"29\">\n        <div class=\"absolute inset-0 isometric-base\" data-kid=\"30\">\n          \n          <div class=\"absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[450px] bg-white border border-[var(--k-color-border)] shadow-[30px_30px_60px_rgba(0,0,0,0.05)]\" data-kid=\"31\">\n            <div class=\"absolute inset-0 opacity-10\" style=\"background-image: linear-gradient(var(--k-color-primary) 1px, transparent 1px), linear-gradient(90deg, var(--k-color-primary) 1px, transparent 1px); background-size: 25px 25px;\" data-kid=\"32\"></div>\n            \n            \n            <div class=\"absolute top-8 left-8 w-[280px] h-[180px] bg-[var(--k-color-bg-surface)] border border-[var(--k-color-border)] flex items-center justify-center overflow-hidden transform-gpu translate-z-20 group cursor-pointer shadow-[0_15px_30px_rgba(0,0,0,0.1)]\" data-kid=\"33\">\n              <video src=\"https://videos.pexels.com/video-files/28561594/12421537_640_360_30fps.mp4\" poster=\"https://images.pexels.com/videos/28561594/3d-rendering-abstract-ai-animation-28561594.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=630&w=1200\" autoplay muted loop playsinline class=\"w-full h-full object-cover opacity-60 group-hover:opacity-100 transition-opacity\" data-kid=\"34\"></video>\n              <div class=\"scanline\" data-kid=\"35\"></div>\n              <div class=\"absolute bottom-2 left-2 font-mono text-[6px] text-[var(--k-color-primary)]/50\" data-kid=\"36\">CORE_PROCESSOR_v4.2</div>\n            </div>\n\n            \n            <div class=\"absolute bottom-12 right-20 w-32 h-32 transform-style-preserve-3d\" data-kid=\"37\">\n              <div class=\"absolute inset-0 bg-[var(--k-color-primary)] border-l-4 border-t-4 border-[var(--k-color-accent)]/40 flex items-center justify-center transform-gpu translate-z-40 shadow-[15px_15px_30px_rgba(0,0,0,0.2)] animate-float-subtle\" data-kid=\"38\">\n                <i class=\"ti ti-cpu text-5xl text-white\" data-kid=\"39\"></i>\n              </div>\n              <div class=\"absolute inset-0 bg-[var(--k-color-primary-hover)] border border-white/5 transform-gpu translate-z-0 translate-x-4 translate-y-4\" data-kid=\"40\"></div>\n            </div>\n\n            \n            <div class=\"absolute top-1/2 right-4 w-24 h-24 transform-style-preserve-3d -translate-y-1/2\" data-kid=\"41\">\n              <div class=\"absolute inset-0 glass-panel flex items-center justify-center transform-gpu translate-z-80 hover:translate-z-100 transition-all duration-500\" data-kid=\"42\">\n                <i class=\"ti ti-microphone text-4xl text-[var(--k-color-primary)]\" data-kid=\"43\"></i>\n              </div>\n            </div>\n\n            \n            <div class=\"absolute top-4 right-16 w-16 h-10 bg-[var(--k-color-bg-surface)] border border-[var(--k-color-border)] transform-gpu translate-z-120 flex items-center justify-center\" data-kid=\"44\">\n              <div class=\"w-full px-2 space-y-1\" data-kid=\"45\">\n                <div class=\"h-0.5 w-full bg-[var(--k-color-primary)]/20\" data-kid=\"46\"></div>\n                <div class=\"h-0.5 w-2/3 bg-[var(--k-color-primary)]/10\" data-kid=\"47\"></div>\n              </div>\n            </div>\n\n            \n            <div class=\"absolute bottom-4 left-4 w-12 h-12 border border-[var(--k-color-accent)]/30 transform-gpu translate-z-150 animate-pulse\" data-kid=\"48\"></div>\n            <div class=\"absolute bottom-20 left-12 w-2 h-2 bg-[var(--k-color-accent)] transform-gpu translate-z-200\" data-kid=\"49\"></div>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"absolute top-0 right-0 w-[800px] h-[800px] bg-[var(--k-color-primary)]/5 rounded-full blur-[120px] -translate-y-1/2 translate-x-1/2\" data-kid=\"50\"></div>\n    <div class=\"absolute bottom-0 left-0 w-64 h-full border-r border-[var(--k-color-border)] bg-gradient-to-r from-[var(--k-color-bg-surface)] to-transparent\" data-kid=\"51\"></div>\n  </section>\n\n  \n  <section class=\"py-20 relative bg-white text-[var(--k-color-text-primary)] overflow-hidden border-t border-[var(--k-color-border)]\" data-kid=\"52\">\n    <div class=\"absolute inset-0 opacity-[0.03]\" style=\"background-image: radial-gradient(var(--k-color-text-primary) 1px, transparent 1px); background-size: 30px 30px;\" data-kid=\"53\"></div>\n    \n    <div class=\"container mx-auto px-12\" data-kid=\"54\">\n      <div class=\"max-w-2xl mb-10\" data-kid=\"55\">\n        <h2 class=\"text-[10px] font-mono tracking-[0.4em] uppercase text-[var(--k-color-primary)] mb-3\" data-kid=\"56\">Architecture</h2>\n        <h3 class=\"text-5xl font-black tracking-tighter uppercase mb-4 font-heading\" data-kid=\"57\">Operational Workflow</h3>\n        <p class=\"text-[var(--k-color-text-secondary)] leading-relaxed font-light text-sm max-w-lg\" data-kid=\"58\">Each phase of the reconstruction is executed with architectural rigor, ensuring your performance is optimized for the highest technical standards.</p>\n      </div>\n\n      <div class=\"relative isometric-container\" data-kid=\"59\">\n        \n        <div class=\"w-full max-w-5xl mx-auto space-y-4\" data-kid=\"60\">\n          \n          \n          <div class=\"flex items-center gap-12 group\" data-kid=\"61\">\n            <div class=\"w-1/3 text-right\" data-kid=\"62\">\n              <span class=\"font-mono text-xs text-[var(--k-color-primary)] block mb-1\" data-kid=\"63\">PHASE_01</span>\n              <h4 class=\"text-2xl font-bold mb-2\" data-kid=\"64\">Data Ingestion</h4>\n              <p class=\"text-[var(--k-color-text-muted)] text-xs leading-relaxed ml-auto max-w-sm\" data-kid=\"65\">Your technical artifacts and career history are parsed using advanced NLP protocols for structural integrity.</p>\n            </div>\n            <div class=\"relative z-40 stair-block shrink-0\" data-kid=\"66\">\n              <div class=\"w-44 h-24 stair-block-face border border-[var(--k-color-text-primary)] flex items-center justify-center transform-gpu rotate-x-[45deg] rotate-z-[-45deg] shadow-[10px_10px_0px_var(--k-color-text-primary)]\" data-kid=\"67\">\n                <i class=\"ti ti-database text-[var(--k-color-primary)] text-4xl transform-gpu rotate-z-[45deg] rotate-x-[-45deg]\" data-kid=\"68\"></i>\n              </div>\n            </div>\n            <div class=\"flex-1 text-9xl font-black text-[var(--k-color-text-primary)]/5 font-mono select-none leading-none opacity-20\" data-kid=\"69\">01</div>\n          </div>\n\n          \n          <div class=\"flex items-center gap-12 flex-row-reverse group\" data-kid=\"70\">\n            <div class=\"w-1/3 text-left\" data-kid=\"71\">\n              <span class=\"font-mono text-xs text-[var(--k-color-primary)] block mb-1\" data-kid=\"72\">PHASE_02</span>\n              <h4 class=\"text-2xl font-bold mb-2\" data-kid=\"73\">Architectural Analysis</h4>\n              <p class=\"text-[var(--k-color-text-muted)] text-xs leading-relaxed max-w-sm\" data-kid=\"74\">AI constructs a predictive model of your interview persona, identifying patterns and structural weaknesses.</p>\n            </div>\n            <div class=\"relative z-30 stair-block shrink-0\" data-kid=\"75\">\n              <div class=\"w-44 h-24 bg-[var(--k-color-primary)] border border-[var(--k-color-text-primary)] flex items-center justify-center transform-gpu rotate-x-[45deg] rotate-z-[-45deg] shadow-[10px_10px_0px_var(--k-color-text-primary)]\" data-kid=\"76\">\n                <i class=\"ti ti-brain text-white text-4xl transform-gpu rotate-z-[45deg] rotate-x-[-45deg]\" data-kid=\"77\"></i>\n              </div>\n            </div>\n            <div class=\"flex-1 text-9xl font-black text-[var(--k-color-text-primary)]/5 font-mono select-none text-right leading-none opacity-20\" data-kid=\"78\">02</div>\n          </div>\n\n          \n          <div class=\"flex items-center gap-12 group\" data-kid=\"79\">\n            <div class=\"w-1/3 text-right\" data-kid=\"80\">\n              <span class=\"font-mono text-xs text-[var(--k-color-primary)] block mb-1\" data-kid=\"81\">PHASE_03</span>\n              <h4 class=\"text-2xl font-bold mb-2\" data-kid=\"82\">Voice Simulation</h4>\n              <p class=\"text-[var(--k-color-text-muted)] text-xs leading-relaxed ml-auto max-w-sm\" data-kid=\"83\">High-fidelity acoustic stress testing through real-time AI simulation protocols.</p>\n            </div>\n            <div class=\"relative z-20 stair-block shrink-0\" data-kid=\"84\">\n              <div class=\"w-44 h-24 stair-block-face border border-[var(--k-color-text-primary)] flex items-center justify-center transform-gpu rotate-x-[45deg] rotate-z-[-45deg] shadow-[10px_10px_0px_var(--k-color-text-primary)]\" data-kid=\"85\">\n                <i class=\"ti ti-microphone text-[var(--k-color-primary)] text-4xl transform-gpu rotate-z-[45deg] rotate-x-[-45deg]\" data-kid=\"86\"></i>\n              </div>\n            </div>\n            <div class=\"flex-1 text-8xl font-black text-[var(--k-color-text-primary)]/5 font-mono select-none leading-none\" data-kid=\"87\">03</div>\n          </div>\n\n          \n          <div class=\"flex items-center gap-12 flex-row-reverse group\" data-kid=\"88\">\n            <div class=\"w-1/3 text-left\" data-kid=\"89\">\n              <span class=\"font-mono text-xs text-[var(--k-color-primary)] block mb-1\" data-kid=\"90\">PHASE_04</span>\n              <h4 class=\"text-2xl font-bold mb-2\" data-kid=\"91\">Metric Feedback</h4>\n              <p class=\"text-[var(--k-color-text-muted)] text-xs leading-relaxed max-w-sm\" data-kid=\"92\">Detailed analytics reports on architectural consistency, clarity, and technical delivery.</p>\n            </div>\n            <div class=\"relative z-10 stair-block shrink-0\" data-kid=\"93\">\n              <div class=\"w-44 h-24 bg-[var(--k-color-accent)] border border-[var(--k-color-text-primary)] flex items-center justify-center transform-gpu rotate-x-[45deg] rotate-z-[-45deg] shadow-[10px_10px_0px_var(--k-color-text-primary)]\" data-kid=\"94\">\n                <i class=\"ti ti-report-analytics text-[var(--k-color-text-primary)] text-4xl transform-gpu rotate-z-[45deg] rotate-x-[-45deg]\" data-kid=\"95\"></i>\n              </div>\n            </div>\n            <div class=\"flex-1 text-8xl font-black text-[var(--k-color-text-primary)]/5 font-mono select-none text-right leading-none\" data-kid=\"96\">04</div>\n          </div>\n\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-24 relative bg-[var(--k-color-bg-surface)] overflow-hidden min-h-[750px] flex items-center\" data-kid=\"97\">\n    \n    <div class=\"absolute inset-0 z-0\" data-kid=\"98\">\n      <img src=\"https://images.unsplash.com/photo-1579487785973-74d2ca7abdd5?auto=format&w=1440&q=80&fit=crop\" class=\"w-full h-full object-cover blur-3xl opacity-5 scale-110\" decoding=\"async\" loading=\"lazy\" data-kid=\"99\">\n      <div class=\"absolute inset-0 bg-gradient-to-b from-[var(--k-color-bg-surface)] via-transparent to-[var(--k-color-bg-surface)]\" data-kid=\"100\"></div>\n    </div>\n\n    <div class=\"container mx-auto px-12 relative z-10\" data-kid=\"101\">\n      <div class=\"grid grid-cols-1 lg:grid-cols-2 gap-24 items-center\" data-kid=\"102\">\n        <div data-kid=\"103\">\n          <h2 class=\"text-xs font-mono tracking-[0.3em] uppercase text-[var(--k-color-primary)] mb-4\" data-kid=\"104\">Analysis</h2>\n          <h3 class=\"text-5xl font-black tracking-tighter text-[var(--k-color-text-primary)] mb-8 font-heading\" data-kid=\"105\">Multi-Layered <br data-kid=\"106\">Performance Metrics</h3>\n          <p class=\"text-[var(--k-color-text-secondary)] text-lg leading-relaxed mb-10 max-w-lg font-light\" data-kid=\"107\">\n            Our depth-layered glass dashboards provide a physical visualization of your progress. Inspect every dimension of your interview technique through spatial data structures.\n          </p>\n          \n          <div class=\"space-y-6\" data-kid=\"108\">\n            <div class=\"flex items-start gap-4 group\" data-kid=\"109\">\n              <div class=\"w-10 h-10 bg-[var(--k-color-primary)]/10 border border-[var(--k-color-primary)]/20 flex items-center justify-center shrink-0 group-hover:bg-[var(--k-color-primary)] transition-colors\" data-kid=\"110\">\n                <i class=\"ti ti-radar text-[var(--k-color-primary)] group-hover:text-white\" data-kid=\"111\"></i>\n              </div>\n              <div data-kid=\"112\">\n                <h4 class=\"text-[var(--k-color-text-primary)] font-bold mb-1\" data-kid=\"113\">Radar Analysis</h4>\n                <p class=\"text-sm text-[var(--k-color-text-muted)]\" data-kid=\"114\">Visualizing 12 distinct technical dimensions in real-time.</p>\n              </div>\n            </div>\n            <div class=\"flex items-start gap-4 group\" data-kid=\"115\">\n              <div class=\"w-10 h-10 bg-[var(--k-color-primary)]/10 border border-[var(--k-color-primary)]/20 flex items-center justify-center shrink-0 group-hover:bg-[var(--k-color-primary)] transition-colors\" data-kid=\"116\">\n                <i class=\"ti ti-wave-sine text-[var(--k-color-primary)] group-hover:text-white\" data-kid=\"117\"></i>\n              </div>\n              <div data-kid=\"118\">\n                <h4 class=\"text-[var(--k-color-text-primary)] font-bold mb-1\" data-kid=\"119\">Acoustic Fidelity</h4>\n                <p class=\"text-sm text-[var(--k-color-text-muted)]\" data-kid=\"120\">Analyzing speech patterns for structural clarity and confidence.</p>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"relative h-[600px] isometric-container\" data-kid=\"121\">\n          <div class=\"absolute inset-0 transform-gpu rotate-y-[-25deg] rotate-x-[15deg] scale-110\" data-kid=\"122\">\n            \n            \n            <div class=\"absolute top-0 right-0 w-[380px] h-[480px] glass-panel p-8 transform-gpu translate-z-[-120px] opacity-40\" data-kid=\"123\">\n              <div class=\"h-32 w-full bg-[var(--k-color-bg-surface)] border border-[var(--k-color-border)] mb-6 relative overflow-hidden\" data-kid=\"124\">\n                <div class=\"absolute inset-0 opacity-10\" style=\"background-image: repeating-linear-gradient(0deg, var(--k-color-primary), var(--k-color-primary) 1px, transparent 1px, transparent 10px); background-size: 100% 10px;\" data-kid=\"125\"></div>\n              </div>\n              <div class=\"space-y-4\" data-kid=\"126\">\n                <div class=\"h-2 w-full bg-[var(--k-color-bg-surface)]\" data-kid=\"127\"></div>\n                <div class=\"h-2 w-3/4 bg-[var(--k-color-bg-surface)]\" data-kid=\"128\"></div>\n                <div class=\"h-2 w-1/2 bg-[var(--k-color-bg-surface)]\" data-kid=\"129\"></div>\n              </div>\n            </div>\n\n            \n            <div class=\"absolute top-10 right-10 w-[380px] h-[480px] glass-panel-accent p-8 transform-gpu translate-z-0 shadow-2xl\" data-kid=\"130\">\n              <div class=\"flex justify-between items-center mb-10\" data-kid=\"131\">\n                <span class=\"font-mono text-[10px] text-[var(--k-color-primary)]\" data-kid=\"132\">DATA_STREAM: ACTIVE</span>\n                <i class=\"ti ti-chart-dots text-[var(--k-color-primary)] animate-pulse\" data-kid=\"133\"></i>\n              </div>\n              <div class=\"aspect-square w-full relative mb-8\" data-kid=\"134\">\n                <div class=\"absolute inset-0 rounded-full border border-[var(--k-color-primary)]/10 animate-spin-slow\" data-kid=\"135\"></div>\n                <div class=\"absolute inset-4 rounded-full border border-[var(--k-color-primary)]/20 border-dashed\" data-kid=\"136\"></div>\n                <div class=\"absolute inset-0 flex items-center justify-center\" data-kid=\"137\">\n                  <div class=\"text-center\" data-kid=\"138\">\n                    <div class=\"text-4xl font-black text-[var(--k-color-text-primary)]\" data-kid=\"139\">98.2</div>\n                    <div class=\"text-[8px] font-mono text-[var(--k-color-text-muted)] uppercase\" data-kid=\"140\">Fidelity_Score</div>\n                  </div>\n                </div>\n              </div>\n              <div class=\"flex gap-1 items-end h-16\" data-kid=\"141\">\n                <div class=\"flex-1 bg-[var(--k-color-primary)]/20 h-8\" data-kid=\"142\"></div>\n                <div class=\"flex-1 bg-[var(--k-color-primary)]/40 h-12\" data-kid=\"143\"></div>\n                <div class=\"flex-1 bg-[var(--k-color-primary)]/60 h-16\" data-kid=\"144\"></div>\n                <div class=\"flex-1 bg-[var(--k-color-primary)]/40 h-10\" data-kid=\"145\"></div>\n                <div class=\"flex-1 bg-[var(--k-color-primary)]/20 h-6\" data-kid=\"146\"></div>\n              </div>\n            </div>\n\n            \n            <div class=\"absolute top-20 right-20 w-[380px] h-[480px] bg-white border border-[var(--k-color-border)] p-10 transform-gpu translate-z-[120px] shadow-[0_60px_100px_rgba(0,0,0,0.06)] group cursor-pointer hover:translate-z-[150px] trans