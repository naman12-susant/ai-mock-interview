s=\"w-1.5 h-1.5 bg-[var(--k-color-accent)] rounded-full\" data-kid=\"167\"></div>\n                <div class=\"w-1.5 h-1.5 bg-[var(--k-color-accent)] rounded-full\" data-kid=\"168\"></div>\n              </div>\n            </div>\n\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-24 relative bg-[var(--k-color-bg-page)] overflow-hidden group\" data-kid=\"169\">\n    <div class=\"absolute inset-0 grid-bg opacity-40\" data-kid=\"170\"></div>\n    <div class=\"container mx-auto px-12 text-center relative z-10\" data-kid=\"171\">\n      <div class=\"max-w-4xl mx-auto\" data-kid=\"172\">\n        <h2 class=\"text-7xl font-black tracking-tighter text-[var(--k-color-text-primary)] mb-8 uppercase perspective-text leading-tight font-heading\" data-kid=\"173\">\n          Initialize <br data-kid=\"174\">\n          <span class=\"text-[var(--k-color-primary)]\" data-kid=\"175\">Your Future.</span>\n        </h2>\n        <p class=\"text-lg text-[var(--k-color-text-secondary)] mb-12 leading-relaxed max-w-xl mx-auto font-light\" data-kid=\"176\">\n          Join the architectural elite. Secure your technical future through our precision-engineered reconstruction protocols.\n        </p>\n        <div class=\"flex flex-col sm:flex-row items-center justify-center gap-6 font-mono\" data-kid=\"177\">\n          <button class=\"w-full sm:w-auto bg-[var(--k-color-primary)] text-white px-12 py-6 text-[10px] tracking-[0.3em] font-bold hover:bg-[var(--k-color-primary-hover)] transition-all border-b-4 border-[var(--k-color-accent)] hover:border-b-0 hover:translate-y-1 cursor-pointer\" data-kid=\"178\">\n            DEPLOY_SYSTEM_CORE\n          </button>\n          <button class=\"w-full sm:w-auto border border-[var(--k-color-border)] text-[var(--k-color-text-muted)] px-12 py-6 text-[10px] tracking-[0.3em] font-bold hover:bg-[var(--k-color-bg-surface)] hover:text-[var(--k-color-text-primary)] transition-all cursor-pointer\" data-kid=\"179\">\n            REVIEW_PROTOCOL\n          </button>\n        </div>\n      </div>\n    </div>\n    \n    <div class=\"absolute top-0 left-1/2 -translate-x-1/2 w-px h-20 bg-gradient-to-b from-[var(--k-color-primary)] to-transparent\" data-kid=\"180\"></div>\n    <div class=\"absolute bottom-0 left-1/2 -translate-x-1/2 w-px h-20 bg-gradient-to-t from-[var(--k-color-primary)] to-transparent\" data-kid=\"181\"></div>\n  </section>\n\n  \n  <footer class=\"py-20 bg-[var(--k-color-bg-surface)] border-t border-[var(--k-color-border)] font-mono text-[10px] tracking-widest text-[var(--k-color-text-muted)] uppercase\" data-kid=\"182\">\n    <div class=\"container mx-auto px-12\" data-kid=\"183\">\n      <div class=\"grid grid-cols-2 md:grid-cols-4 gap-12 mb-20\" data-kid=\"184\">\n        <div class=\"col-span-2 md:col-span-1\" data-kid=\"185\">\n          <div class=\"flex items-center gap-2 text-[var(--k-color-text-primary)] mb-8\" data-kid=\"186\">\n            <div class=\"w-6 h-6 bg-[var(--k-color-primary)] flex items-center justify-center\" data-kid=\"187\">\n              <i class=\"ti ti-cpu text-white text-[10px]\" data-kid=\"188\"></i>\n            </div>\n            <span class=\"font-bold tracking-tighter text-sm\" data-kid=\"189\">AUSTERE.TECH</span>\n          </div>\n          <p class=\"leading-loose normal-case text-[var(--k-color-text-secondary)]\" data-kid=\"190\">Architectural AI for the next generation of technical leadership. Precision by design.</p>\n        </div>\n        <div data-kid=\"191\">\n          <h4 class=\"text-[var(--k-color-text-primary)] mb-6\" data-kid=\"192\">Protocols</h4>\n          <ul class=\"space-y-4\" data-kid=\"193\">\n            <li data-kid=\"194\"><a href=\"#\" class=\"hover:text-[var(--k-color-primary)] transition-colors\" data-kid=\"195\">Reconstruction</a></li>\n            <li data-kid=\"196\"><a href=\"#\" class=\"hover:text-[var(--k-color-primary)] transition-colors\" data-kid=\"197\">Simulation</a></li>\n            <li data-kid=\"198\"><a href=\"#\" class=\"hover:text-[var(--k-color-primary)] transition-colors\" data-kid=\"199\">Verification</a></li>\n          </ul>\n        </div>\n        <div data-kid=\"200\">\n          <h4 class=\"text-[var(--k-color-text-primary)] mb-6\" data-kid=\"201\">Network</h4>\n          <ul class=\"space-y-4\" data-kid=\"202\">\n            <li data-kid=\"203\"><a href=\"#\" class=\"hover:text-[var(--k-color-primary)] transition-colors\" data-kid=\"204\">Nodes</a></li>\n            <li data-kid=\"205\"><a href=\"#\" class=\"hover:text-[var(--k-color-primary)] transition-colors\" data-kid=\"206\">Archives</a></li>\n            <li data-kid=\"207\"><a href=\"#\" class=\"hover:text-[var(--k-color-primary)] transition-colors\" data-kid=\"208\">Status</a></li>\n          </ul>\n        </div>\n        <div data-kid=\"209\">\n          <h4 class=\"text-[var(--k-color-text-primary)] mb-6\" data-kid=\"210\">Connect</h4>\n          <ul class=\"space-y-4\" data-kid=\"211\">\n            <li data-kid=\"212\"><a href=\"#\" class=\"hover:text-[var(--k-color-primary)] transition-colors\" data-kid=\"213\">Terminal</a></li>\n            <li data-kid=\"214\"><a href=\"#\" class=\"hover:text-[var(--k-color-primary)] transition-colors\" data-kid=\"215\">Contact</a></li>\n            <li data-kid=\"216\"><a href=\"#\" class=\"hover:text-[var(--k-color-primary)] transition-colors\" data-kid=\"217\">GitHub</a></li>\n          </ul>\n        </div>\n      </div>\n      <div class=\"flex flex-col md:flex-row justify-between items-center pt-8 border-t border-[var(--k-color-border)]\" data-kid=\"218\">\n        <p data-kid=\"219\">© 2024 AUSTERE_TECHNOLOGY_GROUP. ALL_RIGHTS_RESERVED.</p>\n        <div class=\"flex gap-8 mt-4 md:mt-0\" data-kid=\"220\">\n          <span data-kid=\"221\">LATENCY: 12ms</span>\n          <span data-kid=\"222\">SECURITY: AES-256</span>\n          <span class=\"text-[var(--k-color-success)]\" data-kid=\"223\">SYSTEM_ACTIVE</span>\n     