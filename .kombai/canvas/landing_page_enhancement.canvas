      },
      "html": "\n<div class=\"bg-[var(--k-color-bg-page)] text-[var(--k-color-text-primary)] font-[var(--k-font-family-body)] selection:bg-[var(--k-color-primary)] selection:text-[var(--k-color-secondary)]\" data-kid=\"0\">\n  \n  <style data-kid=\"1\">\n    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Space+Mono&display=swap');\n    @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n    .font-heading { font-family: var(--k-font-family-heading); }\n    .font-body { font-family: var(--k-font-family-body); }\n    .font-mono { font-family: 'Space Mono', monospace; }\n\n    @keyframes tunnel-rotate {\n      0% { transform: rotate(0deg) scale(1); }\n      50% { transform: rotate(180deg) scale(1.05); }\n      100% { transform: rotate(360deg) scale(1); }\n    }\n    \n    @keyframes float {\n      0%, 100% { transform: translateY(0) rotate(0); }\n      50% { transform: translateY(-15px) rotate(1deg); }\n    }\n\n    @keyframes refraction-shimmer {\n      0% { background-position: -200% 0; }\n      100% { background-position: 200% 0; }\n    }\n\n    .glass-panel {\n      background: rgba(255, 255, 255, 0.03);\n      backdrop-filter: blur(24px) saturate(180%);\n      -webkit-backdrop-filter: blur(24px) saturate(180%);\n      border: 1px solid rgba(255, 255, 255, 0.08);\n    }\n\n    .glass-refractive-rim {\n      box-shadow: \n        inset 0 1px 1px rgba(255, 255, 255, 0.2),\n        inset 0 -1px 1px rgba(0, 0, 0, 0.4),\n        0 4px 24px rgba(0, 0, 0, 0.5);\n    }\n\n    .neon-cyan-glow {\n      box-shadow: 0 0 30px rgba(0, 255, 255, 0.15), inset 0 0 15px rgba(0, 255, 255, 0.05);\n      border-color: rgba(0, 255, 255, 0.2);\n    }\n\n    .text-glow-primary {\n      text-shadow: 0 0 12px rgba(0, 255, 255, 0.4);\n    }\n\n    .clip-shard-1 { clip-path: polygon(0% 15%, 100% 0%, 92% 88%, 8% 100%); }\n    .clip-shard-2 { clip-path: polygon(12% 0%, 100% 18%, 88% 100%, 0% 82%); }\n    .clip-shard-3 { clip-path: polygon(4% 4%, 96% 0%, 100% 92%, 0% 100%); }\n\n    .refraction-overlay {\n      background: linear-gradient(\n        105deg,\n        transparent 30%,\n        rgba(255, 255, 255, 0.05) 45%,\n        rgba(255, 255, 255, 0.15) 50%,\n        rgba(255, 255, 255, 0.05) 55%,\n        transparent 70%\n      );\n      background-size: 200% 100%;\n      animation: refraction-shimmer 8s infinite linear;\n    }\n\n    .perspective-container {\n      perspective: 2000px;\n    }\n  </style>\n\n  \n  <nav class=\"absolute top-0 left-0 w-full z-50 px-8 py-8\" data-kid=\"2\">\n    <div class=\"max-w-7xl mx-auto flex items-center justify-between glass-panel glass-refractive-rim px-8 py-4 rounded-2xl\" data-kid=\"3\">\n      <div class=\"flex items-center gap-3\" data-kid=\"4\">\n        <div class=\"w-10 h-10 bg-[var(--k-color-primary)] rounded-lg flex items-center justify-center shadow-[0_0_20px_rgba(0,255,255,0.5)]\" data-kid=\"5\">\n          <i class=\"ti ti-layers-intersect text-[var(--k-color-secondary)] text-2xl\" data-kid=\"6\"></i>\n        </div>\n        <span class=\"font-heading text-2xl font-black tracking-tighter text-glow-primary\" data-kid=\"7\">PORTAL.AI</span>\n      </div>\n      <div class=\"hidden md:flex items-center gap-10 font-medium text-[var(--k-color-text-secondary)]\" data-kid=\"8\">\n        <a href=\"#\" class=\"hover:text-[var(--k-color-primary)] transition-colors text-sm uppercase tracking-widest\" data-kid=\"9\">Modules</a>\n        <a href=\"#\" class=\"hover:text-[var(--k-color-primary)] transition-colors text-sm uppercase tracking-widest\" data-kid=\"10\">Simulations</a>\n        <a href=\"#\" class=\"hover:text-[var(--k-color-primary)] transition-colors text-sm uppercase tracking-widest\" data-kid=\"11\">Enterprise</a>\n        <a href=\"#\" class=\"hover:text-[var(--k-color-primary)] transition-colors text-sm uppercase tracking-widest\" data-kid=\"12\">Network</a>\n      </div>\n      <button class=\"px-6 py-2 bg-white/5 border border-white/10 hover:bg-white/10 rounded-xl font-bold transition-all text-xs uppercase tracking-tighter\" data-kid=\"13\">\n        Access Node\n      </button>\n    </div>\n  </nav>\n\n  \n  <section class=\"relative h-[1100px] flex items-center justify-center overflow-hidden\" data-kid=\"14\">\n    \n    <div class=\"absolute inset-0 flex items-center justify-center pointer-events-none\" data-kid=\"15\">\n      <div class=\"absolute w-[1500px] h-[1500px] border-[1px] border-[var(--k-color-primary)]/10 rounded-full animate-[tunnel-rotate_60s_linear_infinite]\" data-kid=\"16\"></div>\n      <div class=\"absolute w-[1200px] h-[1200px] border-[2px] border-[var(--k-color-primary)]/5 rounded-full animate-[tunnel-rotate_45s_linear_infinite_reverse]\" data-kid=\"17\"></div>\n      <div class=\"absolute w-[900px] h-[900px] border-[40px] border-[var(--k-color-accent)]/5 rounded-full blur-3xl\" data-kid=\"18\"></div>\n      <div class=\"absolute w-[600px] h-[600px] border-[1px] border-[var(--k-color-primary)]/20 rounded-full animate-[tunnel-rotate_30s_linear_infinite]\" data-kid=\"19\"></div>\n      \n      \n      <div class=\"w-[400px] h-[400px] bg-[var(--k-color-primary)] rounded-full blur-[180px] opacity-10\" data-kid=\"20\"></div>\n    </div>\n\n    <div class=\"relative z-10 max-w-6xl mx-auto px-6 text-center mb-32\" data-kid=\"21\">\n      <div class=\"glass-panel glass-refractive-rim p-16 md:p-24 rounded-[64px] neon-cyan-glow relative overflow-hidden group\" data-kid=\"22\">\n        <div class=\"refraction-overlay absolute inset-0 pointer-events-none\" data-kid=\"23\"></div>\n        <div class=\"absolute -top-32 -left-32 w-64 h-64 bg-[var(--k-color-primary)]/10 blur-[100px] rounded-full\" data-kid=\"24\"></div>\n        \n        <div class=\"inline-flex items-center gap-3 px-5 py-2 rounded-full bg-[var(--k-color-primary)]/10 border border-[var(--k-color-primary)]/20 mb-10 text-[10px] font-black tracking-[0.3em] text-[var(--k-color-primary)] uppercase\" data-kid=\"25\">\n          <i class=\"ti ti-sparkles text-sm\" data-kid=\"26\"></i>\n          Neural Synthetic Environments\n        </div>\n        \n        <h1 class=\"text-6xl md:text-8xl lg:text-9xl font-black font-heading leading-[0.85] tracking-tighter mb-10 text-white\" data-kid=\"27\">\n          BEYOND <span class=\"text-transparent border-white/20 [-webkit-text-stroke:1px_rgba(255,255,255,0.3)]\" data-kid=\"28\">THE</span><br data-kid=\"29\">\n          <span class=\"text-transparent bg-clip-text bg-gradient-to-r from-[var(--k-color-primary)] via-white to-[var(--k-color-primary)] drop-shadow-[0_0_20px_rgba(0,255,255,0.4)]\" data-kid=\"30\">GLASS</span>\n        </h1>\n        \n        <p class=\"text-lg md:text-xl text-[var(--k-color-text-secondary)] max-w-2xl mx-auto mb-14 leading-relaxed font-medium\" data-kid=\"31\">\n          The high-fidelity portal for executive mastery. Simulate elite interviews with adaptive AI agents and forensic biometric feedback.\n        </p>\n        \n        <div class=\"flex flex-col sm:flex-row items-center justify-center gap-6\" data-kid=\"32\">\n          <button class=\"w-full sm:w-auto px-12 py-6 bg-[var(--k-color-primary)] text-[var(--k-color-secondary)] font-black rounded-2xl text-lg hover:scale-105 hover:shadow-[0_0_60px_rgba(0,255,255,0.5)] transition-all flex items-center justify-center gap-3 active:scale-95 group\" data-kid=\"33\">\n            INITIATE PORTAL\n            <i class=\"ti ti-chevron-right text-xl group-hover:translate-x-1 transition-transform\" data-kid=\"34\"></i>\n          </button>\n          <button class=\"w-full sm:w-auto px-12 py-6 glass-panel border-white/10 hover:bg-white/10 rounded-2xl text-lg font-bold transition-all text-white\" data-kid=\"35\">\n            EXPLORE NODES\n          </button>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"absolute bottom-16 left-0 w-full flex justify-center gap-6 md:gap-12 px-6\" data-kid=\"36\">\n      <div class=\"glass-panel glass-refractive-rim px-8 py-5 rounded-2xl flex items-center gap-5 animate-[float_4s_ease-in-out_infinite] border-white/5 hover:border-[var(--k-color-primary)]/40 transition-colors group\" data-kid=\"37\">\n        <div class=\"w-12 h-12 bg-white/5 rounded-xl flex items-center justify-center text-[var(--k-color-primary)] shadow-[0_0_15px_rgba(0,255,255,0.2)]\" data-kid=\"38\">\n          <i class=\"ti ti-users text-2xl\" data-kid=\"39\"></i>\n        </div>\n        <div data-kid=\"40\">\n          <div class=\"text-2xl font-black font-heading text-white\" data-kid=\"41\">12.4K</div>\n          <div class=\"text-[10px] text-[var(--k-color-text-muted)] font-black uppercase tracking-widest\" data-kid=\"42\">Active nodes</div>\n        </div>\n      </div>\n      <div class=\"glass-panel glass-refractive-rim px-8 py-5 rounded-2xl flex items-center gap-5 animate-[float_5s_ease-in-out_infinite_0.5s] border-white/5 hover:border-[var(--k-color-primary)]/40 transition-colors group\" data-kid=\"43\">\n        <div class=\"w-12 h-12 bg-white/5 rounded-xl flex items-center justify-center text-[var(--k-color-primary)] shadow-[0_0_15px_rgba(0,255,255,0.2)]\" data-kid=\"44\">\n          <i class=\"ti ti-bolt text-2xl\" data-kid=\"45\"></i>\n        </div>\n        <div data-kid=\"46\">\n          <div class=\"text-2xl font-black font-heading text-white\" data-kid=\"47\">99.8%</div>\n          <div class=\"text-[10px] text-[var(--k-color-text-muted)] font-black uppercase tracking-widest\" data-kid=\"48\">Precision rate</div>\n        </div>\n      </div>\n      <div class=\"glass-panel glass-refractive-rim px-8 py-5 rounded-2xl flex items-center gap-5 animate-[float_6s_ease-in-out_infinite_1s] border-white/5 hover:border-[var(--k-color-primary)]/40 transition-colors group\" data-kid=\"49\">\n        <div class=\"w-12 h-12 bg-white/5 rounded-xl flex items-center justify-center text-[var(--k-color-primary)] shadow-[0_0_15px_rgba(0,255,255,0.2)]\" data-kid=\"50\">\n          <i class=\"ti ti-award text-2xl\" data-kid=\"51\"></i>\n        </div>\n        <div data-kid=\"52\">\n          <div class=\"text-2xl font-black font-heading text-white\" data-kid=\"53\">L8+</div>\n          <div class=\"text-[10px] text-[var(--k-color-text-muted)] font-black uppercase tracking-widest\" data-kid=\"54\">Average Tier</div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-48 relative overflow-hidden\" data-kid=\"55\">\n    <div class=\"absolute top-0 right-0 w-[800px] h-[800px] bg-[var(--k-color-primary)]/5 rounded-full blur-[150px] pointer-events-none\" data-kid=\"56\"></div>\n    \n    <div class=\"max-w-7xl mx-auto px-6\" data-kid=\"57\">\n      <div class=\"flex flex-col md:flex-row md:items-end justify-between mb-32 gap-10\" data-kid=\"58\">\n        <div class=\"max-w-2xl\" data-kid=\"59\">\n          <div class=\"text-[var(--k-color-primary)] font-mono text-sm tracking-widest mb-4 uppercase\" data-kid=\"60\">// SYSTEM_MODULES</div>\n          <h2 class=\"text-5xl md:text-7xl font-black font-heading tracking-tighter text-white mb-6\" data-kid=\"61\">TRAINING<br data-kid=\"62\">VECTORS</h2>\n          <p class=\"text-xl text-[var(--k-color-text-secondary)]\" data-kid=\"63\">Cold-glass precision for warm-blooded performance. Calibrated for depth.</p>\n        </div>\n        <div class=\"flex gap-4\" data-kid=\"64\">\n          <div class=\"w-14 h-14 rounded-full border border-white/10 flex items-center justify-center hover:bg-white/5 cursor-pointer text-white\" data-kid=\"65\">\n            <i class=\"ti ti-chevron-left text-2xl\" data-kid=\"66\"></i>\n          </div>\n          <div class=\"w-14 h-14 rounded-full border border-[var(--k-color-primary)]/30 flex items-center justify-center bg-[var(--k-color-primary)]/10 hover:bg-[var(--k-color-primary)]/20 cursor-pointer text-[var(--k-color-primary)]\" data-kid=\"67\">\n            <i class=\"ti ti-chevron-right text-2xl\" data-kid=\"68\"></i>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"grid grid-cols-1 md:grid-cols-3 gap-10 perspective-container\" data-kid=\"69\">\n        \n        \n        <div class=\"group relative h-[580px] transition-all duration-700 [transform:rotateX(10deg)_rotateY(-10deg)] hover:[transform:rotateX(0deg)_rotateY(0deg)] cursor-pointer\" data-kid=\"70\">\n          <div class=\"absolute inset-0 bg-gradient-to-br from-[var(--k-color-primary)]/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity rounded-[32px]\" data-kid=\"71\"></div>\n          <div class=\"relative h-full glass-panel glass-refractive-rim rounded-[32px] p-12 flex flex-col justify-between overflow-hidden\" data-kid=\"72\">\n            <div class=\"absolute top-0 right-0 w-32 h-32 bg-[var(--k-color-primary)]/5 rounded-full blur-2xl -translate-y-1/2 translate-x-1/2\" data-kid=\"73\"></div>\n            <div data-kid=\"74\">\n              <div class=\"w-20 h-20 bg-white/5 rounded-2xl flex items-center justify-center mb-10 group-hover:scale-110 transition-transform\" data-kid=\"75\">\n                <i class=\"ti ti-brain text-4xl text-[var(--k-color-primary)]\" data-kid=\"76\"></i>\n              </div>\n              <h3 class=\"text-3xl font-bold mb-6 font-heading text-white\" data-kid=\"77\">Cognitive Stress</h3>\n              <p class=\"text-[var(--k-color-text-secondary)] leading-relaxed group-hover:text-white transition-colors\" data-kid=\"78\">\n                High-pressure cognitive load tests. Measure your decision latency under synthetic market duress.\n              </p>\n            </div>\n            <div class=\"pt-10 border-t border-white/5 flex items-center justify-between\" data-kid=\"79\">\n              <span class=\"text-[var(--k-color-primary)] font-mono text-[10px] uppercase tracking-widest\" data-kid=\"80\">Vector_Alpha</span>\n              <div class=\"w-10 h-10 rounded-full bg-white/5 flex items-center justify-center group-hover:bg-[var(--k-color-primary)] group-hover:text-[var(--k-color-secondary)] transition-all\" data-kid=\"81\">\n                <i class=\"ti ti-plus\" data-kid=\"82\"></i>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        \n        <div class=\"group relative h-[580px] transition-all duration-700 [transform:rotateX(10deg)_rotateY(0deg)] hover:[transform:rotateX(0deg)_rotateY(0deg)] cursor-pointer\" data-kid=\"83\">\n          <div class=\"absolute -inset-1 bg-[var(--k-color-primary)]/20 blur-xl opacity-0 group-hover:opacity-100 transition-all rounded-[32px]\" data-kid=\"84\"></div>\n          <div class=\"relative h-full glass-panel glass-refractive-rim rounded-[32px] p-12 flex flex-col justify-between overflow-hidden border-[var(--k-color-primary)]/20 shadow-[0_20px_50px_rgba(0,0,0,0.6)]\" data-kid=\"85\">\n            <div class=\"refraction-overlay absolute inset-0 opacity-20 pointer-events-none\" data-kid=\"86\"></div>\n            <div data-kid=\"87\">\n              <div class=\"w-20 h-20 bg-[var(--k-color-primary)] rounded-2xl flex items-center justify-center mb-10 shadow-[0_0_30px_rgba(0,255,255,0.4)] group-hover:scale-110 transition-transform\" data-kid=\"88\">\n                <i class=\"ti ti-microphone text-4xl text-[var(--k-color-secondary)]\" data-kid=\"89\"></i>\n              </div>\n              <h3 class=\"text-3xl font-bold mb-6 font-heading text-white\" data-kid=\"90\">Vocal Authority</h3>\n              <p class=\"text-white/80 leading-relaxed group-hover:text-white transition-colors\" data-kid=\"91\">\n                AI-driven analysis of tonal weight and micro-fluctuations. Build undeniable command in every syllable.\n              </p>\n            </div>\n            <div class=\"pt-10 border-t border-white/10 flex items-center justify-between\" data-kid=\"92\">\n              <span class=\"text-[var(--k-color-primary)] font-mono text-[10px] uppercase tracking-widest font-black\" data-kid=\"93\">CORE_MODULE</span>\n              <div class=\"w-10 h-10 rounded-full bg-[var(--k-color-primary)] text-[var(--k-color-secondary)] flex items-center justify-center shadow-[0_0_20px_rgba(0,255,255,0.4)]\" data-kid=\"94\">\n                <i class=\"ti ti-arrow-up-right\" data-kid=\"95\"></i>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        \n        <div class=\"group relative h-[580px] transition-all duration-700 [transform:rotateX(10deg)_rotateY(10deg)] hover:[transform:rotateX(0deg)_rotateY(0deg)] cursor-pointer\" data-kid=\"96\">\n          <div class=\"absolute inset-0 bg-gradient-to-bl from-[var(--k-color-primary)]/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity rounded-[32px]\" data-kid=\"97\"></div>\n          <div class=\"relative h-full glass-panel glass-refractive-rim rounded-[32px] p-12 flex flex-col justify-between overflow-hidden\" data-kid=\"98\">\n            <div data-kid=\"99\">\n              <div class=\"w-20 h-20 bg-white/5 rounded-2xl flex items-center justify-center mb-10 group-hover:scale-110 transition-transform\" data-kid=\"100\">\n                <i class=\"ti ti-stack-2 text-4xl text-[var(--k-color-primary)]\" data-kid=\"101\"></i>\n              </div>\n              <h3 class=\"text-3xl font-bold mb-6 font-heading text-white\" data-kid=\"102\">Semantic Logic</h3>\n              <p class=\"text-[var(--k-color-text-secondary)] leading-relaxed group-hover:text-white transition-colors\" data-kid=\"103\">\n                Recursive reasoning challenges that adapt to your logical architecture. Map your mental shortcuts.\n              </p>\n            </div>\n            <div class=\"pt-10 border-t border-white/5 flex items-center justify-between\" data-kid=\"104\">\n              <span class=\"text-[var(--k-color-primary)] font-mono text-[10px] uppercase tracking-widest\" data-kid=\"105\">Vector_Delta</span>\n              <div class=\"w-10 h-10 rounded-full bg-white/5 flex items-center justify-center group-hover:bg-[var(--k-color-primary)] group-hover:text-[var(--k-color-secondary)] transition-all\" data-kid=\"106\">\n                <i class=\"ti ti-settings\" data-kid=\"107\"></i>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-48 bg-[#0F0F0F] relative overflow-hidden\" data-kid=\"108\">\n    <div class=\"absolute inset-0 opacity-20 mix-blend-overlay\" data-kid=\"109\">\n      <img src=\"https://images.unsplash.com/photo-1626908013351-800ddd734b8a?auto=format&w=1600&q=80\" class=\"w-full h-full object-cover grayscale\" alt=\"Biometric Texture\" decoding=\"async\" loading=\"lazy\" data-kid=\"110\">\n    </div>\n    <div class=\"max-w-7xl mx-auto px-6 relative z-10\" data-kid=\"111\">\n      <div class=\"grid grid-cols-1 lg:grid-cols-2 gap-24 items-center\" data-kid=\"112\">\n        <div class=\"relative\" data-kid=\"113\">\n          <div class=\"absolute -top-12 -left-12 w-48 h-48 bg-[var(--k-color-primary)]/10 rounded-full blur-[80px]\" data-kid=\"114\"></div>\n          <div class=\"relative rounded-[40px] glass-panel glass-refractive-rim p-2 overflow-hidden shadow-2xl group\" data-kid=\"115\">\n            <div class=\"aspect-video relative overflow-hidden rounded-[36px]\" data-kid=\"116\">\n              <img src=\"https://images.unsplash.com/photo-1612520557101-48a83a15d1e9?auto=format&w=1200&q=80\" class=\"w-full h-full object-cover group-hover:scale-105 transition-transform duration-[5s]\" alt=\"Neural Analysis\" decoding=\"async\" loading=\"lazy\" data-kid=\"117\">\n              <div class=\"absolute inset-0 bg-gradient-to-t from-[var(--k-color-bg-page)] via-transparent to-transparent\" data-kid=\"118\"></div>\n              \n              <div class=\"absolute bottom-8 left-8 right-8 glass-panel rounded-2xl p-6 border-white/10 backdrop-blur-md\" data-kid=\"119\">\n                <div class=\"flex items-center gap-4\" data-kid=\"120\">\n                  <div class=\"w-12 h-12 bg-[var(--k-color-primary)] rounded-full flex items-center justify-center text-[var(--k-color-secondary)] shadow-lg animate-pulse\" data-kid=\"121\">\n                    <i class=\"ti ti-scan text-xl\" data-kid=\"122\"></i>\n                  </div>\n                  <div data-kid=\"123\">\n                    <div class=\"font-bold text-lg text-white\" data-kid=\"124\">Biometric Array Active</div>\n                    <div class=\"text-xs text-[var(--k-color-primary)] font-mono tracking-widest uppercase\" data-kid=\"125\">Sampling 420 indices / sec</div>\n                  </div>\n                </div>\n              </div>\n            </div>\n          </div>\n          \n          <div class=\"absolute -bottom-16 -right-16 w-56 h-56 glass-panel glass-refractive-rim clip-shard-1 animate-[float_8s_ease-in-out_infinite] z-20 flex items-center justify-center\" data-kid=\"126\">\n             <i class=\"ti ti-activity-heartbeat text-5xl text-[var(--k-color-primary)]/40\" data-kid=\"127\"></i>\n          </div>\n        </div>\n        \n        <div data-kid=\"128\">\n          <div class=\"text-[var(--k-color-primary)] font-mono text-sm tracking-widest mb-6 uppercase\" data-kid=\"129\">ANALYSIS_VISIBILITY</div>\n          <h2 class=\"text-5xl md:text-8xl font-black font-heading leading-[0.95] tracking-tighter text-white mb-8\" data-kid=\"130\">\n            QUANTIFY<br data-kid=\"131\"> \n            <span class=\"text-[var(--k-color-primary)] text-glow-primary\" data-kid=\"132\">INTUITION</span>\n          </h2>\n          <p class=\"text-xl text-[var(--k-color-text-secondary)] mb-12 leading-relaxed\" data-kid=\"133\">\n            Our Glass-Vision engine translates subconscious markers into actionable data. We don't just coach; we map the neural architecture of your leadership presence.\n          </p>\n          <ul class=\"space-y-8\" data-kid=\"134\">\n            <li class=\"flex items-start gap-6 group\" data-kid=\"135\">\n              <div class=\"w-10 h-10 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center mt-1 group-hover:border-[var(--k-color-primary)]/50 transition-colors\" data-kid=\"136\">\n                <i class=\"ti ti-eye-check text-[var(--k-color-primary)] text-xl\" data-kid=\"137\"></i>\n              </div>\n              <div data-kid=\"138\">\n                <h4 class=\"text-2xl font-bold text-white mb-2\" data-kid=\"139\">Ocular Engagement</h4>\n                <p class=\"text-[var(--k-color-text-muted)] group-hover:text-[var(--k-color-text-secondary)] transition-colors\" data-kid=\"140\">Micro-tracking of pupil dilation and focus distribution during high-stakes queries.</p>\n              </div>\n            </li>\n            <li class=\"flex items-start gap-6 group\" data-kid=\"141\">\n              <div class=\"w-10 h-10 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center mt-1 group-hover:border-[var(--k-color-primary)]/50 transition-colors\" data-kid=\"142\">\n                <i class=\"ti ti-cpu text-[var(--k-color-primary)] text-xl\" data-kid=\"143\"></i>\n              </div>\n              <div data-kid=\"144\">\n                <h4 class=\"text-2xl font-bold text-white mb-2\" data-kid=\"145\">Neural Payload Analysis</h4>\n                <p class=\"text-[var(--k-color-text-muted)] group-hover:text-[var(--k-color-text-secondary)] transition-colors\" data-kid=\"146\">Evaluation of vocabulary complexity vs verbal delivery speed for authenticity mapping.</p>\n              </div>\n            </li>\n          </ul>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-48 relative overflow-hidden h-[1200px]\" data-kid=\"147\">\n    <div class=\"max-w-7xl mx-auto px-6 text-center mb-32\" data-kid=\"148\">\n      <div class=\"text-[var(--k-color-primary)] font-mono text-sm tracking-widest mb-4 uppercase\" data-kid=\"149\">ECHO_CHAMBER</div>\n      <h2 class=\"text-6xl md:text-9xl font-black font-heading tracking-tighter text-white mb-4\" data-kid=\"150\">SUCCESS VOICES</h2>\n      <p class=\"text-xl text-[var(--k-color-text-secondary)] max-w-2xl mx-auto\" data-kid=\"151\">Resonances from the individuals who transcended the glass barrier.</p>\n    </div>\n\n    \n    <div class=\"relative max-w-7xl mx-auto px-6 grid grid-cols-12 gap-8 h-[700px]\" data-kid=\"152\">\n      \n      \n      <div class=\"col-start-1 col-span-5 relative self-start glass-panel glass-refractive-rim clip-shard-1 p-14 rotate-[-3deg] animate-[float_7s_ease-in-out_infinite] hover:scale-105 transition-all z-20 group shadow-[0_40px_100px_rgba(0,0,0,0.8)] border-[var(--k-color-primary)]/10\" data-kid=\"153\">\n        <div class=\"refraction-overlay absolute inset-0 pointer-events-none opacity-40\" data-kid=\"154\"></div>\n        <div class=\"flex items-center gap-6 mb-10\" data-kid=\"155\">\n          <img src=\"https://images.unsplash.com/photo-1573497019236-17f8177b81e8?auto=format&w=150&q=80&fit=crop\" class=\"w-20 h-20 rounded-full border-2 border-[var(--k-color-primary)]/40 p-1 shadow-[0_0_20px_rgba(0,255,255,0.2)]\" alt=\"Elena Rodriguez\" decoding=\"async\" loading=\"lazy\" data-kid=\"156\">\n          <div class=\"text-left\" data-kid=\"157\">\n            <h4 class=\"text-2xl font-black font-heading text-white\" data-kid=\"158\">Elena Rodriguez</h4>\n            <p class=\"text-[var(--k-color-primary)] font-mono text-[10px] uppercase tracking-widest font-black\" data-kid=\"159\">L7 Principal @ Meta</p>\n          </div>\n        </div>\n        <p class=\"text-xl text-white font-medium italic leading-relaxed mb-8\" data-kid=\"160\">\n          \"The simulations were so hyper-realistic that the actual panel felt like low-stakes rehearsal. Bespoke engineering for the elite.\"\n        </p>\n        <div class=\"flex gap-2 text-[var(--k-color-primary)]\" data-kid=\"161\">\n          <i class=\"ti ti-star-filled\" data-kid=\"162\"></i><i class=\"ti ti-star-filled\" data-kid=\"163\"></i><i class=\"ti ti-star-filled\" data-kid=\"164\"></i><i class=\"ti ti-star-filled\" data-kid=\"165\"></i><i class=\"ti ti-star-filled\" data-kid=\"166\"></i>\n        </div>\n      </div>\n\n      \n      <div class=\"col-start-8 col-span-5 relative self-center glass-panel glass-refractive-rim clip-shard-2 p-12 rotate-[5deg] animate-[float_9s_ease-in-out_infinite_1s] hover:scale-105 transition-all z-10 opacity-60 hover:opacity-100 shadow-2xl border-white/5\" data-kid=\"167\">\n        <div class=\"flex items-center gap-5 mb-8\" data-kid=\"168\">\n          <img src=\"https://images.unsplash.com/photo-1586232902955-df204f34b36e?auto=format&w=120&q=80&fit=crop\" class=\"w-16 h-16 rounded-full border border-white/20 p-1\" alt=\"Marcus Chen\" decoding=\"async\" loading=\"lazy\" data-kid=\"169\">\n          <div class=\"text-left\" data-kid=\"170\">\n            <h4 class=\"text-xl font-black font-heading text-white\" data-kid=\"171\">Marcus Chen</h4>\n            <p class=\"text-[var(--k-color-text-muted)] font-mono text-[9px] uppercase tracking-widest\" data-kid=\"172\">VP Product @ Stripe</p>\n          </div>\n        </div>\n        <p class=\"text-lg text-[var(--k-color-text-secondary)] italic leading-relaxed\" data-kid=\"173\">\n          \"The vocal biometric feedback caught an anxiety marker I didn't even know I had. Fixed it in 3 sessions.\"\n        </p>\n      </div>\n\n      \n      <div class=\"col-start-3 col-span-7 absolute -bottom-[10%] glass-panel glass-refractive-rim clip-shard-3 p-16 rotate-[1deg] animate-[float_10s_ease-in-out_infinite_0.5s] hover:scale-105 transition-all z-30 shadow-[0_80px_150px_rgba(0,0,0,0.9)] border-[var(--k-color-primary)]/20\" data-kid=\"174\">\n        <div class=\"refraction-overlay absolute inset-0 opacity-30 pointer-events-none\" data-kid=\"175\"></div>\n        <div class=\"flex items-center justify-between mb-12\" data-kid=\"176\">\n          <div class=\"flex items-center gap-6\" data-kid=\"177\">\n            <img src=\"https://images.unsplash.com/photo-1611432579402-7037e3e2c1e4?auto=format&w=150&q=80&fit=crop\" class=\"w-24 h-24 rounded-full border-4 border-white/5 shadow-2xl\" alt=\"Sarah Jenkins\" decoding=\"async\" loading=\"lazy\" data-kid=\"178\">\n            <div class=\"text-left\" data-kid=\"179\">\n              <h4 class=\"text-3xl font-black font-heading text-white\" data-kid=\"180\">Sarah Jenkins</h4>\n              <p class=\"text-[var(--k-color-primary)] font-mono text-[11px] uppercase tracking-[0.3em] font-black\" data-kid=\"181\">Sr Researcher @ OpenAI</p>\n            </div>\n          </div>\n          <div class=\"w-20 h-20 bg-[var(--k-color-secondary)] border border-[var(--k-color-primary)]/30 rounded-2xl flex items-center justify-center text-[var(--k-color-primary)] shadow-[0_0_30px_rgba(0,255,255,0.3)]\" data-kid=\"182\">\n             <i class=\"ti ti-brain text-4xl\" data-kid=\"183\"></i>\n          </div>\n        </div>\n        <p class=\"text-3xl text-white font-black leading-tight mb-10 tracking-tight\" data-kid=\"184\">\n          \"The logic vectors are unmatched. Never seen a tool simulate whiteboard pressure this effectively.\"\n        </p>\n        <div class=\"flex items-center gap-5 text-[var(--k-color-text-muted)] font-mono text-[9px] uppercase tracking-[0.4em]\" data-kid=\"185\">\n          <div class=\"h-[1px] flex-grow bg-white/5\" data-kid=\"186\"></div>\n          Identity_Verified_Node_449\n          <div class=\"h-[1px] flex-grow bg-white/5\" data-kid=\"187\"></div>\n        </div>\n      </div>\n\n      \n      <div class=\"absolute inset-0 pointer-events-none opacity-10\" data-kid=\"188\">\n        <div class=\"absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[1000px] h-[1000px] border border-white/10 rounded-full\" data-kid=\"189\"></div>\n        <div class=\"absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[1200px] h-[1200px] border border-white/5 rounded-full\" data-kid=\"190\"></div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-56 relative overflow-hidden\" data-kid=\"191\">\n    <div class=\"absolute inset-0 flex items-center justify-center pointer-events-none\" data-kid=\"192\">\n      <div class=\"w-[1000px] h-[600px] bg-[var(--k-color-primary)]/10 rounded-full blur-[200px]\" data-kid=\"193\"></div>\n      <div class=\"absolute inset-0 bg-[radial-gradient(circle_at_center,transparent_0%,var(--k-color-bg-page)_80%)]\" data-kid=\"194\"></div>\n    </div>\n    \n    <div class=\"max-w-5xl mx-auto px-6 text-center relative z-10\" data-kid=\"195\">\n      <div class=\"glass-panel glass-refractive-rim p-20 md:p-28 rounded-[80px] border-white/10 shadow-[0_120px_200px_rgba(0,0,0,0.7)] group\" data-kid=\"196\">\n        <div class=\"refraction-overlay absolute inset-0 opacity-10 pointer-events-none\" data-kid=\"197\"></div>\n        \n        <div class=\"text-[var(--k-color-primary)] font-mono text-sm tracking-widest mb-10 uppercase font-black\" data-kid=\"198\">Ready_For_Deployment</div>\n        <h2 class=\"text-6xl md:text-9xl font-black font-heading tracking-tighter text-white mb-10 leading-[0.9]\" data-kid=\"199\">\n          INITIATE<br data-kid=\"200\">\n          <span class=\"text-[var(--k-color-primary)]\" data-kid=\"201\">YOUR PORTAL</span>\n        </h2>\n        <p class=\"text-xl text-[var(--k-color-text-secondary)] mb-16 max-w-2xl mx-auto leading-relaxed\" data-kid=\"202\">\n          The node is awaiting your connection. First 3 simulation sequences are unlocked for initial calibration.\n        </p>\n        \n        <button class=\"px-20 py-8 bg-white text-[var(--k-color-secondary)] font-black rounded-[32px] text-2xl hover:scale-105 hover:bg-[var(--k-color-primary)] transition-all duration-700 shadow-[0_0_80px_rgba(255,255,255,0.2)] hover:shadow-[0_0_100px_rgba(0,255,255,0.6)] active:scale-95 group flex items-center gap-6 mx-auto\" data-kid=\"203\">\n          OPEN_THE_DOOR\n          <i class=\"ti ti-door-enter text-4xl group-hover:rotate-6 transition-transform\" data-kid=\"204\"></i>\n        </button>\n        \n        <div class=\"mt-16 flex flex-wrap items-center justify-center gap-10 text-[var(--k-color-text-muted)] text-[10px] font-black tracking-[0.3em] uppercase\" data-kid=\"205\">\n          <div class=\"flex items-center gap-3\" data-kid=\"206\">\n            <i class=\"ti ti-shield-lock text-[var(--k-color-primary)] text-sm\" data-kid=\"207\"></i>\n            GDPR_HARDENED\n          </div>\n          <div class=\"flex items-center gap-3\" data-kid=\"208\">\n            <i class=\"ti ti-key text-[var(--k-color-primary)] text-sm\" data-kid=\"209\"></i>\n            E2E_ENCRYPTED_BIOMETRICS\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <footer class=\"py-24 border-t border-white/5 bg-[#080808]\" data-kid=\"210\">\n    <div class=\"max-w-7xl mx-auto px-6\" data-kid=\"211\">\n      <div class=\"grid grid-cols-1 md:grid-cols-4 gap-16 mb-24\" data-kid=\"212\">\n        <div class=\"col-span-1 md:col-span-1\" data-kid=\"213\">\n          <div class=\"flex items-center gap-3 mb-10\" data-kid=\"214\">\n            <div class=\"w-8 h-8 bg-[var(--k-color-primary)] rounded-lg flex items-center justify-center\" data-kid=\"215\">\n              <i class=\"ti ti-layers-intersect text-[var(--k-color-secondary)] text-xl\" data-kid=\"216\"></i>\n            </div>\n            <span class=\"font-heading text-xl font-black tracking-tighter text-white\" data-kid=\"217\">PORTAL.AI</span>\n          </div>\n          <p class=\"text-[var(--k-color-text-secondary)] leading-relaxed mb-10 text-sm\" data-kid=\"218\">\n            Architecting the future of human-AI synergy. Calibrating next-generation leadership nodes.\n          </p>\n          <div class=\"flex gap-4\" data-kid=\"219\">\n            <div class=\"w-12 h-12 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center hover:bg-[var(--k-color-primary)] hover:text-[var(--k-color-secondary)] transition-all cursor-pointer group\" data-kid=\"220\">\n              <i class=\"ti ti-brand-x text-lg\" data-kid=\"221\"></i>\n            </div>\n            <div class=\"w-12 h-12 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center hover:bg-[var(--k-color-primary)] hover:text-[var(--k-color-secondary)] transition-all cursor-pointer group\" data-kid=\"222\">\n              <i class=\"ti ti-brand-linkedin text-lg\" data-kid=\"223\"></i>\n            </div>\n            <div class=\"w-12 h-12 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center hover:bg-[var(--k-color-primary)] hover:text-[var(--k-color-secondary)] transition-all cursor-pointer group\" data-kid=\"224\">\n              <i class=\"ti ti-brand-discord text-lg\" data-kid=\"225\"></i>\n            </div>\n          </div>\n        </div>\n        \n        <div data-kid=\"226\">\n          <h4 class=\"font-black text-sm uppercase tracking-[0.2em] text-white mb-10\" data-kid=\"227\">Vector_Access</h4>\n          <ul class=\"space-y-6 text-[var(--k-color-text-muted)] text-xs uppercase tracking-widest font-bold\" data-kid=\"228\">\n            <li data-kid=\"229\"><a href=\"#\" class=\"hover:text-[var(--k-color-primary)] transition-colors\" data-kid=\"230\">Portal_Core</a></li>\n            <li data-kid=\"231\"><a href=\"#\" class=\"hover:text-[var(--k-color-primary)] transition-colors\" data-kid=\"232\">Logic_Tunnels</a></li>\n            <li data-kid=\"233\"><a href=\"#\" class=\"hover:text-[var(--k-color-primary)] transition-colors\" data-kid=\"234\">Vocal_Analysis</a></li>\n            <li data-kid=\"235\"><a href=\"#\" class=\"hover:text-[var(--k-color-primary)] transition-colors\" data-kid=\"236\">Neural_Library</a></li>\n          </ul>\n        </div>\n        \n        <div data-kid=\"237\">\n          <h4 class=\"font-black text-sm uppercase tracking-[0.2em] text-white mb-10\" data-kid=\"238\">System_Info</h4>\n          <ul class=\"space-y-6 text-[var(--k-color-text-muted)] text-xs uppercase tracking-widest font-bold\" data-kid=\"239\">\n            <li data-kid=\"240\"><a href=\"#\" class=\"hover:text-[var(--k-color-primary)] transition-colors\" data-kid=\"241\">Mission_Profile</a></li>\n            <li data-kid=\"242\"><a href=\"#\" class=\"hover:text-[var(--k-color-primary)] transition-colors\" data-kid=\"243\">Privacy_Glass</a></li>\n            <li data-kid=\"244\"><a href=\"#\" class=\"hover:text-[var(--k-color-primary)] transition-colors\" data-kid=\"245\">Service_Protocol</a></li>\n            <li data-kid=\"246\"><a href=\"#\" class=\"hover:text-[var(--k-color-primary)] transition-colors\" data-kid=\"247\">Terminal_Access</a></li>\n          </ul>\n        </div>\n        \n        <div data-kid=\"248\">\n          <h4 class=\"font-black text-sm uppercase tracking-[0.2em] text-white mb-10\" data-kid=\"249\">Sync_Updates</h4>\n          <p class=\"text-[var(--k-color-text-secondary)] text-xs mb-8\" data-kid=\"250\">Synchronize your node with our latest training vectors.</p>\n          <div class=\"flex gap-3\" data-kid=\"251\">\n            <input type=\"text\" placeholder=\"Access ID / Email\" class=\"flex-grow bg-white/5 border border-white/10 rounded-xl px-5 py-3 text-xs focus:outline-none focus:border-[var(--k-color-primary)] transition-colors text-white\" data-kid=\"252\">\n            <button class=\"p-3 bg-[var(--k-color-primary)] text-[var(--k-color-secondary)] rounded-xl hover:scale-105 transition-transform shadow-[0_0_15px_rgba(0,255,255,0.3)]\" data-kid=\"253\">\n              <i class=\"ti ti-send\" data-kid=\"254\"></i>\n            </button>\n          </div>\n        </div>\n      </div>\n      \n      <div class=\"pt-12 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-6 text-[9px] font-black tracking-[0.5em] text-white/20 uppercase\" data-kid=\"255\">\n        <p data-kid=\"256\">© 2026 PORTAL_AI_TECHNOLOGIES // ALL_SYSTEMS_OPERATIONAL</p>\n        <div class=\"flex gap-10\" data-kid=\"257\">\n          <span class=\"hover:text-white cursor-pointer transition-colors\" data-kid=\"258\">STATUS:STABLE</span>\n          <span class=\"hover:text-white cursor-pointer transition-colors\" data-kid=\"259\">Uptime:99.999%</span>\n          <span class=\"hover:text-white cursor-pointer transition-colors\" data-kid=\"260\">Region:Global</span>\n        </div>\n      </div>\n    </div>\n  </footer>\n\n</div>\n",
